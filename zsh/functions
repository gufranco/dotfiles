  __log_info "================================================================"
  echo ""

  __sync_redump
  __sync_internet_archive
  __sync_no_intro
  __sync_ossc

  local END_TIME
  END_TIME=$(date +%s)
  local TOTAL_TIME=$((END_TIME - START_TIME))
