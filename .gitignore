# SSH
ssh/*
!ssh/config
!ssh/id_rsa
!ssh/id_rsa.pub
!ssh/id_ed25519
!ssh/id_ed25519.pub

# Mutt
mutt/accounts/*/certificates
mutt/accounts/*/cache/headers/*
!mutt/accounts/*/cache/headers/.gitkeep
mutt/accounts/*/cache/bodies/*
!mutt/accounts/*/cache/bodies/.gitkeep

# GPG
gnupg/crls.d/
gnupg/gpg-agent.conf
gnupg/openpgp-revocs.d/
gnupg/private-keys-v1.d/
gnupg/pubring.kbx
gnupg/random_seed
gnupg/sshcontrol
gnupg/tofu.db
gnupg/trustdb.gpg

# Tmux
tmux/resurrect/
tmux/plugins/*
!tmux/plugins/tpm

# Vim
.tern-port
.netrwhist
plug.vim*
vim/plugged/
coc/extensions/node_modules/
coc/memos.json
