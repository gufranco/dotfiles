################################################################################
# Security
################################################################################
tlsv1.2
# User-agent intentionally omitted to avoid staleness. Add per-invocation if needed.

################################################################################
# Connection
################################################################################
connect-timeout = 30
max-time = 300
max-redirs = 5
location
referer = ";auto"
retry = 3
retry-delay = 1
retry-connrefused

################################################################################
# Performance
################################################################################
http2
compressed
keepalive-time = 60

################################################################################
# Output
################################################################################
show-error

################################################################################
# File Handling
################################################################################
create-dirs
continue-at = -
