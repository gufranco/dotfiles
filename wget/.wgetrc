################################################################################
# Security
################################################################################
https_only = on
check_certificate = on
ca_directory = /etc/ssl/certs
secure_protocol = TLSv1_2
no_parent = on
robots = off
# User-agent intentionally omitted to avoid staleness. Add per-invocation if needed.

################################################################################
# Connection
################################################################################
timeout = 30
dns_timeout = 10
connect_timeout = 10
read_timeout = 60
tries = 3
wait = 1
retry_connrefused = on
max_redirect = 5

################################################################################
# Download
################################################################################
timestamping = on
continue = on
trust_server_names = off
follow_ftp = on
adjust_extension = on
convert_links = off
backup_converted = off

################################################################################
# Encoding
################################################################################
local_encoding = UTF-8
remote_encoding = UTF-8

################################################################################
# Output
################################################################################
verbose = off
progress = bar:force:noscroll

################################################################################
# Performance
################################################################################
limit_rate = 0
waitretry = 3
random_wait = off
passive_ftp = on
prefer_family = IPv4

################################################################################
# Advanced
################################################################################
cookies = on
cache = on
use_proxy = off
dns_cache = on
keep_session_cookies = off
