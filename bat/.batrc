################################################################################
# Theme
################################################################################
--theme="tokyonight_night"

################################################################################
# Show line numbers, Git modifications and file header (but no grid)
################################################################################
--style="numbers,changes,header"

################################################################################
# Use italic text
################################################################################
--italic-text=always

################################################################################
# Add mouse scrolling support in less
################################################################################
--paging=auto

################################################################################
# Map syntax for additional extensions
################################################################################
--map-syntax "*.conf:INI"
--map-syntax "*.env:Bash"
--map-syntax "*.zshrc:Bash"
--map-syntax "*.bashrc:Bash"
--map-syntax ".gitconfig:INI"
--map-syntax ".gitignore:Git Ignore"
--map-syntax "Brewfile:Ruby"
--map-syntax "Dockerfile*:Dockerfile"
--map-syntax "docker-compose*.yml:YAML"
