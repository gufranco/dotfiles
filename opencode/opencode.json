{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "apfel": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Apple Intelligence (apfel)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "apple-foundationmodel": {
          "name": "Apple Intelligence",
          "tool_call": false,
          "limit": {
            "context": 4096,
            "output": 2048
          }
        }
      }
    }
  },
  "small_model": "apfel/apple-foundationmodel",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".next",
      ".output",
      ".turbo",
      ".vercel",
      ".nuxt",
      ".svelte-kit",
      "coverage",
      "__pycache__",
      ".pytest_cache",
      ".mypy_cache",
      "target",
      "vendor",
      ".terraform",
      ".claude"
    ]
  },
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "plan": {
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow"
      }
    }
  }
}
