#!/usr/bin/env bash
#
# gaming - Linux gaming helper functions.
# Verification, launch option helpers, and GPU management.

# Guard: only load on Linux x86_64
if [[ "$(uname)" != "Linux" ]] || [[ "$(dpkg --print-architecture 2>/dev/null)" != "amd64" ]]; then
  # shellcheck disable=SC2317
  return 0 2>/dev/null || true
fi

################################################################################
# gaming-check - Verify all gaming components are working
################################################################################
function gaming-check() {
  local errors=0

  echo ""
  __log_info "==============================================================="
  __log_info "Gaming Setup Verification"
  __log_info "==============================================================="
  echo ""

  # NVIDIA driver
  if __cmd_exists nvidia-smi; then
    local driver_version
    driver_version=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1)
    if [ -n "$driver_version" ]; then
      __log_success "NVIDIA driver: ${driver_version}"
    else
      __log_warning "NVIDIA driver: loaded but no GPU detected"
    fi
  else
    __log_error "NVIDIA driver: not installed"
    ((errors++))
  fi

  # NVIDIA Prime mode
  if __cmd_exists prime-select; then
    local prime_mode
    prime_mode=$(prime-select query 2>/dev/null)
    __log_success "NVIDIA Prime: ${prime_mode}"
  else
    __log_warning "NVIDIA Prime: not installed"
    ((errors++))
  fi

  # Vulkan drivers
  if __cmd_exists vulkaninfo; then
    local vulkan_gpus
    vulkan_gpus=$(vulkaninfo --summary 2>/dev/null | grep "deviceName" | sed 's/.*= //')
    if [ -n "$vulkan_gpus" ]; then
      while IFS= read -r gpu; do
        __log_success "Vulkan GPU: ${gpu}"
      done <<< "$vulkan_gpus"
    else
      __log_warning "Vulkan: no GPUs found"
      ((errors++))
    fi
  else
    __log_error "Vulkan: vulkaninfo not installed"
    ((errors++))
  fi

  # GameMode
  if __cmd_exists gamemoded; then
    if gamemoded -t 2>/dev/null | grep -q "gamemode request succeeded"; then
      __log_success "GameMode: functional"
    else
      __log_warning "GameMode: installed but test failed (check group membership)"
    fi
  else
    __log_error "GameMode: not installed"
    ((errors++))
  fi

  # MangoHud
  if __cmd_exists mangohud; then
    __log_success "MangoHud: installed"
  else
    __log_error "MangoHud: not installed"
    ((errors++))
  fi

  # Gamescope
  if __cmd_exists gamescope; then
    __log_success "Gamescope: installed"
  else
    __log_error "Gamescope: not installed"
    ((errors++))
  fi

  # Kernel parameters
  local max_map
  max_map=$(command sysctl -n vm.max_map_count 2>/dev/null)
  if [ "$max_map" -ge 2147483642 ] 2>/dev/null; then
    __log_success "vm.max_map_count: ${max_map}"
  else
    __log_warning "vm.max_map_count: ${max_map:-unknown} (expected 2147483642)"
    ((errors++))
  fi

  local split_lock
  split_lock=$(command sysctl -n kernel.split_lock_mitigate 2>/dev/null)
  if [ "$split_lock" = "0" ]; then
    __log_success "kernel.split_lock_mitigate: disabled"
  else
    __log_warning "kernel.split_lock_mitigate: ${split_lock:-unknown} (expected 0)"
  fi

  # GE-Proton
  local proton_dir="$HOME/.steam/steam/compatibilitytools.d"
  if [ -d "$proton_dir" ] && [ -n "$(command ls -A "$proton_dir" 2>/dev/null)" ]; then
    local latest_ge
    latest_ge=$(command ls -1 "$proton_dir" | sort -V | tail -1)
    __log_success "GE-Proton: ${latest_ge}"
  else
    __log_warning "GE-Proton: not installed"
    ((errors++))
  fi

  # Steam
  if __cmd_exists steam || dpkg -l steam-launcher 2>/dev/null | grep -q "^ii"; then
    __log_success "Steam: installed"
  else
    __log_error "Steam: not installed"
    ((errors++))
  fi

  # NVIDIA open kernel modules (preferred on Turing+)
  if dpkg -l 2>/dev/null | grep -q "^ii  nvidia-driver-[0-9]*-open"; then
    __log_success "NVIDIA: open kernel modules"
  elif dpkg -l 2>/dev/null | grep -q "^ii  nvidia-driver-[0-9]"; then
    __log_warning "NVIDIA: proprietary modules (expected on pre-Turing MX)"
  fi

  # Suspend/resume hardening
  if grep -q "PreserveVideoMemoryAllocations=1" /etc/modprobe.d/nvidia-power.conf 2>/dev/null; then
    __log_success "NVIDIA: suspend/resume hardening enabled"
  else
    __log_warning "NVIDIA: suspend/resume hardening missing"
    ((errors++))
  fi

  # zram swap
  if command swapon --show 2>/dev/null | grep -q zram; then
    __log_success "zram: active"
  else
    __log_warning "zram: not active"
    ((errors++))
  fi

  # swappiness (must be 180 with zram)
  local swappiness
  swappiness=$(command sysctl -n vm.swappiness 2>/dev/null)
  if [ "$swappiness" = "180" ]; then
    __log_success "vm.swappiness: 180"
  else
    __log_warning "vm.swappiness: ${swappiness:-unknown} (expected 180 with zram)"
  fi

  # XanMod kernel
  if command uname -r | grep -qi xanmod; then
    __log_success "Kernel: $(command uname -r)"
  else
    __log_warning "Kernel: $(command uname -r) (XanMod not booted; reboot?)"
  fi

  # scx_lavd scheduler
  if command systemctl is-active scx.service >/dev/null 2>&1; then
    __log_success "Scheduler: scx service active"
  else
    __log_warning "Scheduler: scx not active (needs XanMod/6.12+ + reboot)"
  fi

  # earlyoom
  if command systemctl is-active earlyoom >/dev/null 2>&1; then
    __log_success "earlyoom: running"
  else
    __log_warning "earlyoom: not running"
    ((errors++))
  fi

  # Controller udev rules (shipped by Valve's steam-launcher)
  if command ls /lib/udev/rules.d/*steam* /usr/lib/udev/rules.d/*steam* >/dev/null 2>&1; then
    __log_success "Steam controller udev rules: present"
  else
    __log_warning "Steam controller udev rules: not found (start Steam once)"
  fi

  # Managed config symlinks
  if [ -L "$HOME/.config/gamemode.ini" ]; then
    __log_success "gamemode.ini: linked"
  else
    __log_warning "gamemode.ini: not linked"
    ((errors++))
  fi

  # Summary
  echo ""
  if [ "$errors" -eq 0 ]; then
    __log_success "All gaming components verified"
  else
    __log_warning "${errors} component(s) need attention"
  fi
  echo ""
}

################################################################################
# gaming-launch-options - Print recommended Steam launch options
################################################################################
function gaming-launch-options() {
  echo ""
  __log_info "Steam Launch Options (copy into game Properties > Launch Options)"
  echo ""
  echo "  Standard (most games):"
  echo "    prime-run gamemoderun mangohud %command%"
  echo ""
  echo "  FSR upscale + frame cap (the key lever on entry GPUs):"
  echo "    render below native and let gamescope upscale + cap frames"
  echo "    prime-run gamescope -W 1920 -H 1080 -w 1280 -h 720 -F fsr --sharpness 5 -r 60 --adaptive-sync --mangoapp -- gamemoderun %command%"
  echo ""
  echo "  CAS sharpening only (no upscale):"
  echo "    prime-run ENABLE_VKBASALT=1 gamemoderun mangohud %command%"
  echo ""
  echo "  Debug mode (write logs to /tmp):"
  echo "    prime-run PROTON_LOG=1 gamemoderun %command%"
  echo ""
  # Note: these GTX 1650 Ti / GeForce MX GPUs have no tensor or RT cores, so
  # DLSS and hardware ray tracing do not apply. If an RTX card is ever added,
  # DLSS is enabled with PROTON_ENABLE_NVAPI=1 (plus PROTON_DLSS_UPGRADE=1 on
  # GE-Proton / proton-cachyos). DXVK_ASYNC is obsolete on DXVK 2.x (GPL).
}
