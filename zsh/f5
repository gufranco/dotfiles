#!/usr/bin/env bash
#
# f5 - Update and reload everything.
# All update helpers live here next to the function that calls them.

################################################################################
# Git repo updater (shared by multiple update functions below)
################################################################################
function __f5_update_git_repo() {
  local repo_dir="$1"
  git -C "$repo_dir" pull --quiet >/dev/null 2>&1 && \
  git -C "$repo_dir" fetch --prune --quiet >/dev/null 2>&1
}

################################################################################
# Individual update steps
################################################################################
function __f5_update_dotfiles() {
  __log_info "Updating dotfiles..."

  if [ ! -d "$HOME/.dotfiles/.git" ]; then
    __log_skip "Dotfiles not a git repository"
    return
  fi

  if __f5_update_git_repo "$HOME/.dotfiles"; then
    if git -C "$HOME/.dotfiles" submodule update --init --recursive --quiet; then
      __log_success "Dotfiles and submodules updated"
    else
      __log_success "Dotfiles updated (submodules had issues)"
    fi
  else
    __log_warning "Failed to update dotfiles"
  fi
}

function __f5_update_aws() {
  if [ ! -d "$HOME/.aws/.git" ]; then
    __log_warning "No AWS configuration repository found"
    return
  fi

  __log_info "Updating AWS configuration..."

  if __f5_update_git_repo "$HOME/.aws"; then
    __log_success "AWS configuration updated"
  else
    __log_warning "Failed to update AWS configuration"
  fi
}

function __f5_update_claude() {
  if [ ! -d "$HOME/.claude/.git" ]; then
    __log_warning "No Claude engineering rules repository found"
    return
  fi

  __log_info "Updating Claude engineering rules..."

  if __f5_update_git_repo "$HOME/.claude"; then
    __log_success "Claude engineering rules updated"
  else
    __log_warning "Failed to update Claude engineering rules"
  fi
}

function __f5_update_vim() {
  if ! __cmd_exists vim; then
    __log_skip "Vim not installed"
    return
  fi

  __log_info "Updating Vim plugins..."
  if vim +PlugUpgrade +PlugUpdate +CocUpdateSync +PlugClean! +qall; then
    __log_success "Vim plugins updated"
  else
    __log_warning "Failed to update Vim plugins"
  fi
}

function __f5_update_plugins() {
  __log_info "Updating Zsh and Tmux plugins..."

  local plugin_count=0
  local plugin_errors=0

  for dir in \
    "$HOME/.oh-my-zsh" \
    "$HOME/.oh-my-zsh/custom"/{themes,plugins}/*/ \
    "$HOME/.tmux/plugins/"*/; do

    [ ! -d "$dir/.git" ] && continue
    [[ "$dir" == "$HOME/.tmux/plugins/tpm/" ]] && continue

    if __f5_update_git_repo "$dir"; then
      ((plugin_count++))
    else
      ((plugin_errors++))
    fi
  done

  if [ "$plugin_errors" -gt 0 ]; then
    __log_warning "Updated $plugin_count plugins ($plugin_errors failed)"
  else
    __log_success "Updated $plugin_count plugins"
  fi
}

function __f5_update_mise() {
  if ! __cmd_exists mise; then
    __log_skip "mise not installed"
    return
  fi

  __log_info "Updating mise runtimes..."

  local upgrade_ok=true
  local prune_ok=true

  mise upgrade --yes >/dev/null 2>&1 || upgrade_ok=false
  mise prune --yes >/dev/null 2>&1 || prune_ok=false

  if $upgrade_ok && $prune_ok; then
    __log_success "mise runtimes updated"
  else
    __log_warning "mise runtimes updated with warnings"
  fi
}

function __f5_update_proton_ge() {
  local proton_dir="$HOME/.steam/steam/compatibilitytools.d"
  if [ ! -d "$proton_dir" ]; then
    __log_skip "GE-Proton not set up"
    return
  fi

  __log_info "Updating GE-Proton..."

  local latest
  latest=$(curl -sL --connect-timeout 10 --max-time 30 \
    https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest \
    | grep tag_name | cut -d '"' -f 4)

  if [ -z "$latest" ]; then
    __log_warning "Could not check GE-Proton version"
    return
  fi

  if [ -d "$proton_dir/$latest" ]; then
    __log_success "GE-Proton ${latest} (up to date)"
    return
  fi

  curl -#fLo "/tmp/${latest}.tar.gz" --connect-timeout 10 --max-time 300 \
    "https://github.com/GloriousEggroll/proton-ge-custom/releases/download/${latest}/${latest}.tar.gz"
  tar -xzf "/tmp/${latest}.tar.gz" -C "$proton_dir"
  rm -f "/tmp/${latest}.tar.gz"
  __log_success "GE-Proton updated to ${latest}"
}

function __f5_update_linux() {
  __log_info "Updating Linux packages..."

  if sudo apt update -qq >/dev/null 2>&1 || sudo apt update; then
    sudo apt dist-upgrade -y -qq >/dev/null 2>&1 || sudo apt dist-upgrade -y
    sudo apt autoremove -y -qq >/dev/null 2>&1 || sudo apt autoremove -y
    sudo apt clean >/dev/null 2>&1 || true
    __log_success "Linux packages updated"
  else
    __log_error "Failed to update Linux packages"
  fi
}

function __f5_update_standalone_tools() {
  __log_info "Updating standalone tools..."

  local updated=0
  local failed=0

  if __cmd_exists starship; then
    if curl -sS --connect-timeout 10 --max-time 120 https://starship.rs/install.sh | sh -s -- --yes >/dev/null 2>&1; then
      updated=$((updated + 1))
    else
      failed=$((failed + 1))
    fi
  fi

  if __cmd_exists zoxide; then
    if curl -sS --connect-timeout 10 --max-time 120 https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash >/dev/null 2>&1; then
      updated=$((updated + 1))
    else
      failed=$((failed + 1))
    fi
  fi

  if __cmd_exists atuin; then
    if curl -sS --connect-timeout 10 --max-time 120 https://setup.atuin.sh | bash -s -- --non-interactive >/dev/null 2>&1; then
      updated=$((updated + 1))
    else
      failed=$((failed + 1))
    fi
  fi

  if [ "$failed" -eq 0 ]; then
    __log_success "Standalone tools updated ($updated tools)"
  else
    __log_warning "Standalone tools updated ($updated ok, $failed failed)"
  fi
}

function __f5_update_macos() {
  __log_info "Updating macOS packages..."

  if brew update; then
    brew bundle --file "$HOME/.dotfiles/Brewfile" || __log_warning "Brewfile sync failed"
    brew bundle cleanup --force --file "$HOME/.dotfiles/Brewfile" || true
    brew upgrade --greedy || __log_warning "Brew upgrade failed"
    brew cleanup -s || true
  else
    __log_warning "Brew update failed"
  fi

  if __cmd_exists mas; then
    mas upgrade && __log_success "Mac App Store apps updated"
  fi

  __macos_post_install_cleanup

  __log_success "macOS packages updated"
}

function __f5_update_python() {
  local pipxfile="$HOME/.dotfiles/Pipxfile"

  ############################################################################
  # pipx CLI tools
  ############################################################################
  if ! __cmd_exists pipx; then
    __log_skip "pipx not installed, skipping CLI tools"
    return
  fi

  if [ ! -f "$pipxfile" ]; then
    __log_skip "Pipxfile not found"
    return
  fi

  __log_info "Updating pipx tools..."

  # Install any package listed in Pipxfile that is not yet installed
  local installed_count=0
  local skip_count=0
  while IFS= read -r pkg || [ -n "$pkg" ]; do
    [[ -z "$pkg" || "$pkg" == \#* ]] && continue
    if pipx list --short 2>/dev/null | awk '{print $1}' | grep -qx "$pkg"; then
      ((skip_count++))
    else
      pipx install "$pkg" --quiet 2>/dev/null && ((installed_count++)) || \
        __log_warning "Failed to install pipx package: $pkg"
    fi
  done < "$pipxfile"

  # Upgrade all installed tools
  pipx upgrade-all --quiet 2>/dev/null || __log_warning "pipx upgrade-all had failures"

  # Remove tools installed via pipx that are no longer in Pipxfile
  local removed_count=0
  while IFS= read -r installed_pkg; do
    [[ -z "$installed_pkg" ]] && continue
    if ! grep -qxE "^[^#].*" "$pipxfile" | grep -qx "$installed_pkg" 2>/dev/null; then
      # Check if it's actually in the file (accounting for comments/blanks)
      local found=false
      while IFS= read -r line || [ -n "$line" ]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        [[ "$line" == "$installed_pkg" ]] && found=true && break
      done < "$pipxfile"
      if ! $found; then
        pipx uninstall "$installed_pkg" --quiet 2>/dev/null && ((removed_count++))
      fi
    fi
  done < <(pipx list --short 2>/dev/null | awk '{print $1}')

  __log_success "pipx tools updated (installed: $installed_count, removed: $removed_count, up-to-date: $skip_count)"
}

function __f5_reload_configs() {
  __log_info "Reloading configurations..."

  if __cmd_exists tmux && [ -n "$TMUX" ]; then
    if tmux source-file ~/.tmux.conf; then
      __log_success "Tmux config reloaded"
    else
      __log_warning "Tmux reload failed"
    fi
  else
    __log_skip "Not in tmux session"
  fi

  # Clear eval cache so tools re-initialize with fresh output
  command rm -rf "${__EVAL_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/zsh/eval-cache}" 2>/dev/null

  # Guard prevents tmux auto-start and token re-init during re-source
  export __F5_RELOADING=1
  # shellcheck disable=SC1091
  if source "$HOME/.zshrc"; then
    __log_success "Zsh config reloaded"
  else
    __log_warning "Zsh reload failed"
  fi
  unset __F5_RELOADING
}

function __f5_show_summary() {
  local f5_end f5_total f5_mins f5_secs

  f5_end=$(date +%s)
  f5_total=$((f5_end - SCRIPT_START_TIME))
  f5_mins=$((f5_total / 60))
  f5_secs=$((f5_total % 60))

  echo ""
  __log_success "==============================================================="
  __log_success "Update completed successfully!"
  __log_success "==============================================================="
  echo ""
  __log_info "Total time: ${f5_mins}m ${f5_secs}s"
  echo ""
}

################################################################################
# Main entry point
################################################################################
function f5() {
  SCRIPT_START_TIME=$(date +%s)
  export SCRIPT_START_TIME

  echo ""
  __log_info "==============================================================="
  __log_info "System Update (F5)"
  __log_info "==============================================================="
  echo ""

  __f5_update_dotfiles
  __f5_update_aws
  __f5_update_claude
  __f5_update_vim
  __f5_update_plugins
  __f5_update_mise

  case "$(uname)" in
    "Linux")
      __f5_update_linux
      __f5_update_standalone_tools
      __f5_update_proton_ge
      ;;
    "Darwin") __f5_update_macos ;;
  esac

  __f5_update_python

  __f5_reload_configs
  __f5_show_summary
}
