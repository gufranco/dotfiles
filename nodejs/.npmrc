################################################################################
# Init
################################################################################
init-author-name=Gustavo Franco
init-author-email=gustavocfranco@gmail.com
init-author-url=https://www.github.com/gufranco
init-license=MIT
init-version=0.0.1

################################################################################
# Registry
################################################################################
registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

################################################################################
# Behavior
################################################################################
update-notifier=false
progress=false
fund=false
audit=false
loglevel=warn

################################################################################
# Network
################################################################################
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

################################################################################
# Security
################################################################################
ignore-scripts=true
engine-strict=true
