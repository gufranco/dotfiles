#!/usr/bin/env bash

################################################################################
# System specific settings
################################################################################
case "$(uname)" in
  "Linux")

    ;;
  "Darwin")
    # Zsh
    export ZSH_DISABLE_COMPFIX=true

    # Homebrew
    export HOMEBREW_NO_ANALYTICS=true
    export HOMEBREW_NO_ENV_HINTS=true
    export HOMEBREW_NO_AUTO_UPDATE=true
    export HOMEBREW_QUIET=true

    # Docker
    # export DOCKER_DEFAULT_PLATFORM="linux/amd64"

    ;;
esac

################################################################################
# Shell
################################################################################
setopt EXTENDED_HISTORY        # Record timestamp with each command
setopt INC_APPEND_HISTORY      # Write to HISTFILE immediately, not on shell exit
setopt HIST_IGNORE_DUPS        # Skip consecutive duplicate entries
setopt HIST_IGNORE_SPACE       # Skip commands starting with a space
setopt HIST_REDUCE_BLANKS      # Remove extra blanks from history entries
setopt HIST_EXPIRE_DUPS_FIRST  # Expire duplicates first when trimming history
setopt HIST_FIND_NO_DUPS       # No duplicates when searching history
setopt HIST_VERIFY             # Show !! expansion before executing
export HISTORY_IGNORE="(cd|ls|[bf]g|clear|exit)"
export HISTSIZE=2147483647
export SAVEHIST=2147483647
export LANG=pt_BR.UTF-8

# Auto-report execution time for commands taking longer than 5 seconds
export REPORTTIME=5

################################################################################
# Completion tuning
################################################################################
# Case-insensitive tab completion (e.g., "doc" matches "Documents")
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
# Include hidden files in completion results
setopt GLOB_DOTS

################################################################################
# File descriptor limit
################################################################################
# Increase open file limit for heavy test suites and watch-mode tools.
# Guard: only raise if current limit is below the target.
if [ "$(ulimit -n)" -lt 10240 ] 2>/dev/null; then
  ulimit -n 10240 2>/dev/null || true
fi

################################################################################
# Terminal
################################################################################
# Enable True Color support (24-bit)
export COLORTERM=truecolor

################################################################################
# Cached eval: cache tool init output keyed by binary mtime.
# Avoids spawning subprocesses on every shell open.
# Cache is invalidated when the binary changes (upgrade, reinstall).
# Run `eval-cache-clear` to force rebuild.
################################################################################
__EVAL_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/eval-cache"

__cached_eval() {
  local cmd="$1"
  shift
  local bin_path
  bin_path="$(command -v "$cmd" 2>/dev/null)" || return 0

  local mtime
  mtime="$(command stat -c '%Y' "$bin_path" 2>/dev/null || command stat -f '%m' "$bin_path" 2>/dev/null)" || return 0
  local cache_key="${cmd}--${mtime}"
  local cache_file="${__EVAL_CACHE_DIR}/${cache_key}"

  if [ -f "$cache_file" ]; then
    # shellcheck disable=SC1090
    source "$cache_file"
  else
    command mkdir -p "$__EVAL_CACHE_DIR"
    # Remove stale caches for this tool
    # NULL_GLOB: let the glob expand to nothing instead of raising a zsh error
    setopt local_options NULL_GLOB
    command rm -f "${__EVAL_CACHE_DIR}/${cmd}--"* 2>/dev/null
    local init_output
    init_output="$("$bin_path" "$@")" || { echo "cached_eval: $cmd init failed" >&2; return 0; }
    printf '%s' "$init_output" > "$cache_file"
    # shellcheck disable=SC1090
    source "$cache_file"
  fi
}

eval-cache-clear() {
  command rm -rf "$__EVAL_CACHE_DIR"
  echo "Eval cache cleared. Restart your shell to rebuild."
}

################################################################################
# direnv
################################################################################
__cached_eval direnv hook zsh

################################################################################
# mise
################################################################################
__cached_eval mise activate zsh

################################################################################
# zoxide (smart cd)
################################################################################
__cached_eval zoxide init zsh

################################################################################
# atuin (shell history)
################################################################################
__cached_eval atuin init zsh --disable-up-arrow

################################################################################
# starship prompt (loads after oh-my-zsh spaceship if both present)
################################################################################
# Uncomment to switch from spaceship to starship:
# command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

################################################################################
# eza
################################################################################
export EZA_CONFIG_DIR="$HOME/.config/eza"

################################################################################
# fzf (Tokyo Night)
################################################################################
export FZF_DEFAULT_OPTS=" \
  --color=fg:#c0caf5,bg:#1a1b26,hl:#bb9af7 \
  --color=fg+:#c0caf5,bg+:#283457,hl+:#7dcfff \
  --color=info:#7aa2f7,prompt:#7aa2f7,pointer:#7dcfff \
  --color=marker:#9ece6a,spinner:#9ece6a,header:#9ece6a \
  --color=border:#414868,label:#c0caf5,query:#c0caf5 \
  --layout=reverse --border=rounded \
  --preview 'bat --color=always --style=numbers --line-range=:500 {} 2>/dev/null || cat {}' \
  --bind 'ctrl-/:toggle-preview' \
  --bind 'ctrl-d:preview-half-page-down' \
  --bind 'ctrl-u:preview-half-page-up' \
  --bind 'ctrl-o:execute(\${EDITOR:-vim} {})'"

# Use fd as fzf's file finder (respects .gitignore, faster than find)
if command -v fd >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
fi

################################################################################
# nnn (Tokyo Night palette indices)
################################################################################
# BLK CHR DIR EXE REG HARDLINK SYMLINK MISSING ORPHAN FIFO SOCK OTHER
export NNN_FCOLORS='0B0B04060000060606000906'

################################################################################
# Oh-my-zsh
################################################################################
export ZSH="$HOME/.oh-my-zsh"
export ZSH_THEME="spaceship"
export DISABLE_AUTO_UPDATE="true"
export HIST_STAMPS="dd/mm/yyyy"
export DISABLE_MAGIC_FUNCTIONS=true
export DISABLE_AUTO_TITLE=true
export ZSH_COMPDUMP="${ZSH_CACHE_DIR:-$HOME/.cache}/.zcompdump-${HOST}-${ZSH_VERSION}"

# SSH Agent
zstyle :omz:plugins:ssh-agent lazy yes
zstyle :omz:plugins:ssh-agent identities id_rsa_personal id_ed25519_personal id_ed25519_onyx

# Plugins
export plugins=(
  gpg-agent
  ssh-agent

  extract

  fzf
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)

################################################################################
# zsh-autosuggestions
################################################################################
# Search history first, fall back to completion engine
export ZSH_AUTOSUGGEST_STRATEGY=(history completion)
# Tokyo Night muted foreground for suggestions
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#565f89"

################################################################################
# Spaceship
################################################################################
export SPACESHIP_USER_SHOW=always
export SPACESHIP_PROMPT_ADD_NEWLINE=false
export SPACESHIP_CHAR_SYMBOL="❯"
export SPACESHIP_CHAR_SUFFIX=" "

################################################################################
# NPM Token
################################################################################
if [ -z "$NPM_TOKEN" ]; then
  if __update_npm_token; then
    # Verify token was loaded successfully (double-check)
    if [ -z "${NPM_TOKEN:-}" ]; then
      # Token loading failed silently, ensure it's unset
      unset NPM_TOKEN
    fi
  else
    # Function returned error, ensure NPM_TOKEN is unset
    unset NPM_TOKEN 2>/dev/null || true
  fi
fi

################################################################################
# GitHub Token
################################################################################
if [ -z "$GITHUB_PAT" ]; then
  if __update_github_token; then
    # Verify token was loaded successfully (double-check)
    if [ -z "${GITHUB_PAT:-}" ]; then
      # Token loading failed silently, ensure it's unset
      unset GITHUB_PAT
    fi
  else
    # Function returned error, ensure GITHUB_PAT is unset
    unset GITHUB_PAT 2>/dev/null || true
  fi
fi

################################################################################
# Workspace folder
################################################################################
if [ ! -e "$HOME/Workspace" ] && [ -d "$HOME/Dropbox/Workspace" ]; then
  ln -s "$HOME/Dropbox/Workspace" "$HOME/Workspace"
fi
