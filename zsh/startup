#!/usr/bin/env bash

################################################################################
# Tmux Auto-Start
################################################################################
# Automatically start tmux when opening a new terminal
# Skip for VSCode and Vim integrated terminals, and during f5 reloads
if [ -z "$TMUX" ] && [ -z "$__F5_RELOADING" ] && [ "$TERM_PROGRAM" != "vscode" ] && [ "$TERM_PROGRAM" != "vim" ] && command -v tmux >/dev/null 2>&1; then
  tmux new-session -A -s main
fi

################################################################################
# Tmux Terminal Settings
################################################################################
# Set proper TERM for tmux sessions (skip for Kitty terminal)
if [ -n "$TMUX" ] && [ "$TERM_PROGRAM" != "kitty" ]; then
  export TERM="tmux-256color"
fi

