#!/usr/bin/env bash

################################################################################
# Internal functions
################################################################################
function __calculate_vm_cores() {
  # Percentage of total CPU cores to allocate
  local percentage=25
  # Minimum number of CPU cores to allocate
  local minimum=2
  # Maximum number of CPU cores to allocate
  local maximum=8

  case "$(uname -s)" in
    Darwin)
      # shellcheck disable=SC2155
      local total="$(sysctl -n hw.ncpu)"

      ;;
    Linux)
      # shellcheck disable=SC2155
      local total="$(nproc)"

      ;;
  esac

  local result=$(( total * percentage / 100 ))

  # Round up to next even number if odd and >= 2
  if [ "$result" -ge 2 ] && [ $(( result % 2 )) -ne 0 ]; then
    result=$(( result + 1 ))
  fi

  if [ "$result" -gt "$maximum" ]; then
    echo "$maximum"

    return
  fi

  if [ "$result" -lt "$minimum" ]; then
    echo "$minimum"

    return
  fi

  echo "$result"
}

function __calculate_vm_memory() {
  # Percentage of total memory to allocate
  local percentage=50
  # Minimum memory to allocate (in GiB)
  local minimum=2
  # Maximum memory to allocate (in GiB)
  local maximum=16

  case "$(uname -s)" in
    Darwin)
      # shellcheck disable=SC2155
      local total=$(( "$(sysctl -n hw.memsize)" / 1024 / 1024 / 1024 ))

      ;;
    Linux)
      # shellcheck disable=SC2155
      local total=$(( "$(grep MemTotal /proc/meminfo | awk '{print $2}')" / 1024 / 1024 ))

      ;;
  esac

  local result=$(( total * percentage / 100 ))

  # Round up to nearest power of 2 up to maximum
  local rounded=1
  while [ "$rounded" -lt "$result" ] && [ "$rounded" -lt "$maximum" ]; do
    rounded=$(( rounded * 2 ))
  done

  if [ "$rounded" -gt "$maximum" ]; then
    echo "$maximum"

    return
  fi

  if [ "$rounded" -lt "$minimum" ]; then
    echo "$minimum"

    return
  fi

  echo "$rounded"
}

function __calculate_vm_storage() {
  # Percentage of total storage to allocate
  local percentage=50
  # Minimum storage to allocate (in GiB)
  local minimum=25
  # Maximum storage to allocate (in GiB)
  local maximum=100

  case "$(uname -s)" in
    Darwin)
      # shellcheck disable=SC2155
      local total=$(( (("$(diskutil info /dev/disk0 | awk -F'[()]' '/Disk Size/ {sub(/ Bytes/, "", $2); print $2}')" / 1073741824) + 255) / 256 * 256 ))

      ;;
    Linux)
      # shellcheck disable=SC2155
      local total=$(( (("$(lsblk -bdno SIZE "/dev/$(lsblk -no pkname "$(df / --output=source | tail -n1)")")" / 1073741824) + 255) / 256 * 256 ))

      ;;
  esac

  local result=$(( (((total * percentage / 100) + 5) / 10) * 10 ))

  if [ "$result" -gt "$maximum" ]; then
    echo "$maximum"

    return
  fi

  if [ "$result" -lt "$minimum" ]; then
    echo "$minimum"

    return
  fi

  echo "$result"
}

function __ensure_docker_compose_plugin() {
  if ! command -v docker-compose > /dev/null 2>&1; then
    return
  fi

  local plugin_dir="${HOME}/.docker/cli-plugins"

  if [ ! -d "$plugin_dir" ]; then
    mkdir -p "$plugin_dir"
  fi

  local plugin_path="${plugin_dir}/docker-compose"
  # shellcheck disable=SC2155
  local compose_bin="$(command -v docker-compose)"

  # shellcheck disable=SC2155
  if [ -L "$plugin_path" ]; then
    local current_target="$(readlink "$plugin_path")"

    if [ "$current_target" != "$compose_bin" ]; then
      rm -f "$plugin_path"

      ln -sf "$compose_bin" "$plugin_path"
    fi
  elif [ -e "$plugin_path" ]; then
    rm -f "$plugin_path"

    ln -sf "$compose_bin" "$plugin_path"
  else
    ln -sf "$compose_bin" "$plugin_path"
  fi

  if [ -L "$plugin_path" ] && [ ! -x "$plugin_path" ]; then
    chmod +x "$plugin_path"
  fi
}

################################################################################
# Colima VM
################################################################################
function __confirm_colima_config() {
  local profile="$1"
  local cores="$2"
  local memory="$3"
  local storage="$4"
  local os_type="$5"
  local arch="$6"

  echo ""
  echo "================================================================================"
  echo "  Colima VM - Configuration"
  echo "================================================================================"
  echo ""
  echo "Profile:          ${profile}"
  echo "Platform:         ${os_type} (${arch})"
  echo ""
  echo "Configuration:"
  echo "  CPU Cores:      ${cores}"
  echo "  Memory:         ${memory}GiB"
  echo "  Disk:           ${storage}GiB"
  echo ""

  if [[ "${CI:-0}" = "1" ]]; then
    return 0
  fi

  read -r "?Do you want to continue with these configurations? (y/N): "
  echo ""

  if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
    return 1
  fi

  return 0
}

function colima-start() {
  # Ensure Docker Compose V2 plugin is properly configured
  __ensure_docker_compose_plugin

  # Get profile name (default to "default" if not provided)
  local profile="${1:-default}"

  # shellcheck disable=SC2155
  local cores="$(__calculate_vm_cores)"
  # shellcheck disable=SC2155
  local memory="$(__calculate_vm_memory)"
  # shellcheck disable=SC2155
  local storage="$(__calculate_vm_storage)"
  # shellcheck disable=SC2155
  local os_type="$(uname -s)"
  # shellcheck disable=SC2155
  local arch="$(uname -m)"

  # Show configuration and ask for confirmation
  __confirm_colima_config "$profile" "$cores" "$memory" "$storage" "$os_type" "$arch" || return 1

  echo ""
  echo "================================================================================"
  echo "  Colima VM - Starting"
  echo "================================================================================"
  echo ""

  case "$os_type" in
    "Darwin")
      case "$arch" in
        "x86_64")
          # Intel Mac - Maximum performance with Virtualization.framework
          echo "Runtime:"
          echo "  Engine:         Docker"
          echo "  VM Type:        Virtualization.framework (Apple native)"
          echo "  Architecture:   x86_64 native (no emulation)"
          echo "  Mount Type:     VirtioFS (kernel-level I/O)"
          echo "  File Watching:  inotify enabled"
          echo ""
          echo "Network:"
          echo "  DNS:            1.1.1.1, 8.8.8.8"
          echo "  Address:        Reachable from host"
          echo ""
          echo "Performance:"
          echo "  Auto Activate:  Enabled"
          echo "  BuildKit:       Enabled (faster builds & I/O)"
          echo "  Inline Cache:   Enabled (persistent cache)"
          echo ""

          command colima start \
            --profile "${profile}" \
            --cpu "${cores}" \
            --memory "${memory}" \
            --disk "${storage}" \
            \
            --runtime "docker" \
            --vm-type "vz" \
            --arch "x86_64" \
            \
            --mount "$HOME:w" \
            --mount-type "virtiofs" \
            --mount-inotify \
            \
            --dns "1.1.1.1" \
            --dns "8.8.8.8" \
            \
            --network-address \
            --activate \
            \
            --env DOCKER_BUILDKIT=1 \
            --env COMPOSE_DOCKER_CLI_BUILD=1 \
            --env BUILDKIT_INLINE_CACHE=1

          ;;
        "arm64")
          # Apple Silicon - Maximum performance with Rosetta 2 support
          echo "Runtime:"
          echo "  Engine:         Docker"
          echo "  VM Type:        Virtualization.framework (Apple native)"
          echo "  Architecture:   ARM64 native + x86_64 via Rosetta 2"
          echo "  Mount Type:     VirtioFS (kernel-level I/O)"
          echo "  File Watching:  inotify enabled"
          echo "  Rosetta 2:      Enabled (x86_64 containers supported)"
          echo ""
          echo "Network:"
          echo "  DNS:            1.1.1.1, 8.8.8.8"
          echo "  Address:        Reachable from host"
          echo ""
          echo "Performance:"
          echo "  Auto Activate:  Enabled"
          echo "  Multi-Arch:     ARM64 + x86_64 simultaneously"
          echo "  BuildKit:       Enabled (faster builds & I/O)"
          echo "  Inline Cache:   Enabled (persistent cache)"
          echo ""

          command colima start \
            --profile "${profile}" \
            --cpu "${cores}" \
            --memory "${memory}" \
            --disk "${storage}" \
            \
            --runtime "docker" \
            --vm-type "vz" \
            --arch "aarch64" \
            --vz-rosetta \
            \
            --mount "$HOME:w" \
            --mount-type "virtiofs" \
            --mount-inotify \
            \
            --dns "1.1.1.1" \
            --dns "8.8.8.8" \
            \
            --network-address \
            --activate \
            \
            --env DOCKER_BUILDKIT=1 \
            --env COMPOSE_DOCKER_CLI_BUILD=1 \
            --env BUILDKIT_INLINE_CACHE=1

          ;;
      esac

      ;;
    "Linux")
      # Linux x86_64 - Maximum performance with KVM
      echo "Runtime:"
      echo "  Engine:         Docker"
      echo "  VM Type:        QEMU with KVM acceleration"
      echo "  Architecture:   x86_64 native"
      echo "  Mount Type:     9p (best for Linux)"
      echo "  File Watching:  inotify enabled"
      echo ""
      echo "Network:"
      echo "  DNS:            1.1.1.1, 8.8.8.8"
      echo "  Address:        Reachable from host"
      echo ""
      echo "Performance:"
      echo "  Auto Activate:  Enabled"
      echo "  KVM:            Hardware acceleration enabled"
      echo "  BuildKit:       Enabled (faster builds & I/O)"
      echo "  Inline Cache:   Enabled (persistent cache)"
      echo ""

      command colima start \
        --profile "${profile}" \
        --cpu "${cores}" \
        --memory "${memory}" \
        --disk "${storage}" \
        \
        --runtime "docker" \
        --vm-type "qemu" \
        --arch "x86_64" \
        \
        --mount "$HOME:w" \
        --mount-type "9p" \
        --mount-inotify \
        \
        --dns "1.1.1.1" \
        --dns "8.8.8.8" \
        \
        --network-address \
        --activate \
        \
        --env DOCKER_BUILDKIT=1 \
        --env COMPOSE_DOCKER_CLI_BUILD=1 \
        --env BUILDKIT_INLINE_CACHE=1

      ;;
  esac
}

function colima-stop() {
  local profile="${1:-default}"

  echo ""
  echo "================================================================================"
  echo "  Colima VM - Stop"
  echo "================================================================================"
  echo ""
  echo "Profile:         ${profile}"
  echo ""

  if [[ "${CI:-0}" = "1" ]]; then
    echo "CI mode detected - auto-confirming..."
    echo ""
  else
    read -r "?Do you want to stop this VM? (y/N): "
    echo ""

    if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  command colima stop --profile "${profile}"
}

function colima-purge() {
  local profile="${1:-default}"

  echo ""
  echo "================================================================================"
  echo "  Colima VM - Purge (WARNING: Destructive Operation)"
  echo "================================================================================"
  echo ""
  echo "Profile:         ${profile}"
  echo ""
  echo "This operation will:"
  echo "  - Stop all Docker containers"
  echo "  - Remove all Docker images, volumes, and networks"
  echo "  - Stop the Colima VM"
  echo "  - Delete the Colima VM and all its data"
  echo ""
  echo "WARNING: This action cannot be undone!"
  echo ""

  if [[ "${CI:-0}" = "1" ]]; then
    echo "CI mode detected - auto-confirming..."
    echo ""
  else
    read -r "?Are you sure you want to continue? (y/N): "
    echo ""

    if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  docker-purge "${profile}"
  command colima stop --profile "${profile}" --force 2>/dev/null || true
  command colima delete --profile "${profile}" --force 2>/dev/null || true
}

################################################################################
# Docker purge
################################################################################
function docker-purge() {
  local profile="${1:-default}"
  # shellcheck disable=SC2155
  local context="$([[ "${profile}" = "default" ]] && echo "colima" || echo "colima-${profile}")"

  DOCKER_CONTEXT="${context}" command docker stop "$(DOCKER_CONTEXT="${context}" command docker ps -aq)" 2>/dev/null || true
  DOCKER_CONTEXT="${context}" command docker system prune -af --volumes --filter "label!=keep" 2>/dev/null || true
  DOCKER_CONTEXT="${context}" command docker builder prune -af 2>/dev/null || true
  DOCKER_CONTEXT="${context}" command docker images -q | xargs -r docker rmi -f 2>/dev/null || true
}

################################################################################
# Mongo
################################################################################
function mongo-init() {
  mkdir -p "$HOME/Docker/Mongo"

  command docker run \
    --detach \
    --hostname mongo \
    --name mongo \
    --restart unless-stopped \
    \
    --cpus "${cores:-2}" \
    --memory "${memory:-2g}" \
    --shm-size 256m \
    \
    --env "MONGO_INITDB_ROOT_USERNAME=mongo" \
    --env "MONGO_INITDB_ROOT_PASSWORD=mongo" \
    \
    --mount "type=bind,source=$HOME/Docker/Mongo,target=/external" \
    --volume "mongo-data:/data/db" \
    --volume "mongo-config:/data/configdb" \
    \
    --publish "127.0.0.1:27017:27017" \
    \
    --log-driver "local" \
    --log-opt "max-size=10m" \
    --log-opt "max-file=3" \
    \
    --health-cmd "mongosh --eval 'db.adminCommand({ping: 1})' --quiet" \
    --health-interval 30s \
    --health-timeout 10s \
    --health-retries 3 \
    \
    mongo:latest
}

function mongo-start() {
  command docker start mongo
}

function mongo-stop() {
  command docker stop mongo
}

function mongo-purge() {
  mongo-stop 2>/dev/null || true
  command docker rm mongo 2>/dev/null || true
  rm -rf "$HOME/Docker/Mongo"
}

function mongo-terminal() {
  command docker exec -it mongo /bin/sh
}

