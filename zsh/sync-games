#!/usr/bin/env bash
#
# sync_games - Sync game library from Myrient and Internet Archive via rclone.

################################################################################
# Common rclone sync wrapper
################################################################################
__sync_collection() {
  local folder="$1"
  local url="$2"
  local current="$3"
  local total="$4"
  local label="${5:-$folder}"
  shift 5

  mkdir -p "./$folder/"
  __log_info "[$current/$total] $label"

  if rclone sync \
    --progress \
    --ignore-case \
    --multi-thread-streams=0 \
    --size-only \
    --delete-excluded \
    --retries 3 \
    --retries-sleep 10s \
    --low-level-retries 10 \
    "$@" \
    "$url" \
    "./$folder/"; then
    __log_success "Completed: $label"
  else
    __log_warning "Failed: $label"
  fi
}

