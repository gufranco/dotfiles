#!/usr/bin/env bash
#
# Infrastructure: Colima VMs, Docker, and containerized services.
# All VM/Docker helpers live here next to the functions that use them.

################################################################################
# Resource calculation for VMs
################################################################################
function __clamp_resource() {
  local value="$1"
  local minimum="$2"
  local maximum="$3"
  local total="$4"

  if [ "$value" -gt "$maximum" ]; then
    echo "$maximum"
    return
  fi

  if [ "$value" -lt "$minimum" ]; then
    if [ "$total" -ge "$minimum" ]; then
      echo "$minimum"
    else
      echo "$total"
    fi
    return
  fi

  echo "$value"
}

function __round_to_power_of_2() {
  local value="$1"
  local rounded=1

  while [ "$rounded" -lt "$value" ]; do
    rounded=$(( rounded * 2 ))
  done

  echo "$rounded"
}

function __calculate_vm_cores() {
  local percentage=50
  local minimum=2
  local maximum=4
  local total

  case "$(uname -s)" in
    Darwin) total="$(sysctl -n hw.ncpu)" ;;
    Linux)  total="$(nproc)" ;;
  esac

  local result=$(( total * percentage / 100 ))

  if [ "$result" -ge 2 ] && [ $(( result % 2 )) -ne 0 ]; then
    result=$(( result + 1 ))
  fi

  __clamp_resource "$result" "$minimum" "$maximum" "$total"
}

function __calculate_vm_memory() {
  local percentage=50
  local minimum=2
  local maximum=8
  local total

  case "$(uname -s)" in
    Darwin) total=$(( "$(sysctl -n hw.memsize)" / 1024 / 1024 / 1024 )) ;;
    Linux)  total=$(( "$(grep MemTotal /proc/meminfo | awk '{print $2}')" / 1024 / 1024 )) ;;
  esac

  local result=$(( total * percentage / 100 ))
  result=$(__round_to_power_of_2 "$result")

  __clamp_resource "$result" "$minimum" "$maximum" "$total"
}

function __calculate_vm_storage() {
  local percentage=25
  local minimum=8
  local maximum=64
  local total

  case "$(uname -s)" in
    Darwin)
      total=$(( (("$(diskutil info /dev/disk0 | awk -F'[()]' '/Disk Size/ {sub(/ Bytes/, "", $2); print $2}')" / 1073741824) + 255) / 256 * 256 ))
      ;;
    Linux)
      total=$(( (("$(lsblk -bdno SIZE "/dev/$(lsblk -no pkname "$(df / --output=source | tail -n1)")")" / 1073741824) + 255) / 256 * 256 ))
      ;;
  esac

  local result=$(( total * percentage / 100 ))
  result=$(__round_to_power_of_2 "$result")

  __clamp_resource "$result" "$minimum" "$maximum" "$total"
}

################################################################################
# Docker helpers
################################################################################
function __ensure_docker_compose_plugin() {
  if ! __cmd_exists docker-compose; then
    __log_info "docker-compose not found, skipping plugin setup"
    return
  fi

  local compose_bin
  compose_bin="$(command -v docker-compose)"

  __safe_link "$compose_bin" "${HOME}/.docker/cli-plugins/docker-compose"
  chmod +x "${HOME}/.docker/cli-plugins/docker-compose" 2>/dev/null
}

function __docker_container_start() {
  local container_name="$1"
  command docker start "$container_name"
}

function __docker_container_stop() {
  local container_name="$1"
  command docker stop "$container_name"
}

function __docker_container_purge() {
  local container_name="$1"
  local data_dir="$HOME/Docker/${container_name^}"

  __docker_container_stop "$container_name" 2>/dev/null || true
  command docker rm "$container_name" 2>/dev/null || true
  rm -rf "$data_dir"
}

function __docker_container_terminal() {
  local container_name="$1"
  local shell="${2:-/bin/sh}"
  command docker exec -it "$container_name" "$shell"
}

function __docker_run_detached() {
  local container_name="$1"
  shift

  command docker run \
    --detach \
    --hostname "$container_name" \
    --name "$container_name" \
    --restart unless-stopped \
    \
    --log-driver "local" \
    --log-opt "max-size=10m" \
    --log-opt "max-file=3" \
    \
    "$@"
}

################################################################################
# User confirmation and display helpers
################################################################################
function __confirm_operation() {
  local prompt="${1:-Do you want to continue?}"

  if [[ "${CI:-0}" = "1" ]]; then
    echo "CI mode detected - auto-confirming..."
    echo ""
    return 0
  fi

  read -r "?${prompt} (y/N): "
  echo ""

  if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
    return 1
  fi

  return 0
}

function __show_header() {
  local title="$1"
  local subtitle="${2:-}"

  echo ""
  echo "================================================================================"
  if [ -n "$subtitle" ]; then
    echo "  ${title} - ${subtitle}"
  else
    echo "  ${title}"
  fi
  echo "================================================================================"
  echo ""
}

function __show_runtime_info() {
  local vm_type="$1"
  local arch_desc="$2"
  local mount_type="$3"
  local extra_info="${4:-}"

  echo "Runtime:"
  echo "  Engine:         Docker"
  echo "  VM Type:        ${vm_type}"
  echo "  Architecture:   ${arch_desc}"
  echo "  Mount Type:     ${mount_type}"
  echo "  File Watching:  inotify enabled"
  [ -n "$extra_info" ] && echo "  ${extra_info}"
  echo ""
  echo "Network:"
  echo "  DNS:            1.1.1.1, 8.8.8.8"
  echo "  Address:        Reachable from host"
  echo ""
}

function __show_performance_info() {
  local extra_info="${1:-}"

  echo "Performance:"
  echo "  Auto Activate:  Enabled"
  [ -n "$extra_info" ] && echo "  ${extra_info}"
  echo "  BuildKit:       Enabled (faster builds & I/O)"
  echo "  Inline Cache:   Enabled (persistent cache)"
  echo ""
}

function __confirm_colima_config() {
  local profile="$1"
  local cores="$2"
  local memory="$3"
  local storage="$4"
  local os_type="$5"
  local arch="$6"

  __show_header "Colima VM" "Configuration"
  echo "Profile:          ${profile}"
  echo "Platform:         ${os_type} (${arch})"
  echo ""
  echo "Configuration:"
  echo "  CPU Cores:      ${cores}"
  echo "  Memory:         ${memory}GiB"
  echo "  Disk:           ${storage}GiB"
  echo ""

  __confirm_operation "Do you want to continue with these configurations?"
}

function __vm_start() {
  local profile="$1"
  local cores="$2"
  local memory="$3"
  local storage="$4"
  local arch="$5"
  shift 5

  command colima start \
    --profile "${profile}" \
    --cpu "${cores}" \
    --memory "${memory}" \
    --disk "${storage}" \
    \
    --runtime "docker" \
    --arch "${arch}" \
    \
    --mount "$HOME:w" \
    --mount-inotify \
    \
    --dns "1.1.1.1" \
    --dns "8.8.8.8" \
    \
    --network-address \
    --activate \
    \
    --env DOCKER_BUILDKIT=1 \
    --env COMPOSE_DOCKER_CLI_BUILD=1 \
    --env BUILDKIT_INLINE_CACHE=1 \
    \
    "$@"
}

################################################################################
# Colima VM management
################################################################################
function colima-start() {
  __ensure_docker_compose_plugin

  local profile="default"
  local cores=""
  local memory=""
  local storage=""
  local os_type
  local arch
  os_type="$(uname -s)"
  arch="$(uname -m)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cores)   cores="$2";   shift 2 ;;
      --memory)  memory="$2";  shift 2 ;;
      --storage) storage="$2"; shift 2 ;;
      *)
        if [[ "$profile" == "default" && "$1" != "--"* ]]; then
          profile="$1"
        fi
        shift
        ;;
    esac
  done

  cores="${cores:-$(__calculate_vm_cores)}"
  memory="${memory:-$(__calculate_vm_memory)}"
  storage="${storage:-$(__calculate_vm_storage)}"

  __confirm_colima_config "$profile" "$cores" "$memory" "$storage" "$os_type" "$arch" || return 1
  __show_header "Colima VM" "Starting"

  case "$os_type" in
    "Darwin")
      case "$arch" in
        "x86_64")
          __show_runtime_info \
            "Virtualization.framework (Apple native)" \
            "x86_64 native (no emulation)" \
            "VirtioFS (kernel-level I/O)"
          __show_performance_info

          __vm_start "$profile" "$cores" "$memory" "$storage" "x86_64" \
            --vm-type "vz" \
            --mount-type "virtiofs"
          ;;

        "arm64")
          __show_runtime_info \
            "Virtualization.framework (Apple native)" \
            "ARM64 native + x86_64 via Rosetta 2" \
            "VirtioFS (kernel-level I/O)" \
            "Rosetta 2:      Enabled (x86_64 containers supported)"
          __show_performance_info "Multi-Arch:     ARM64 + x86_64 simultaneously"

          __vm_start "$profile" "$cores" "$memory" "$storage" "aarch64" \
            --vm-type "vz" \
            --vz-rosetta \
            --mount-type "virtiofs"
          ;;
      esac
      ;;

    "Linux")
      __show_runtime_info \
        "QEMU with KVM acceleration" \
        "x86_64 native" \
        "9p (best for Linux)"
      __show_performance_info "KVM:            Hardware acceleration enabled"

      __vm_start "$profile" "$cores" "$memory" "$storage" "x86_64" \
        --vm-type "qemu" \
        --mount-type "9p"
      ;;
  esac
}

function colima-stop() {
  local profile="${1:-default}"

  __show_header "Colima VM" "Stop"
  echo "Profile:         ${profile}"
  echo ""

  __confirm_operation "Do you want to stop this VM?" || return 1

  command colima stop --profile "${profile}"
}

function colima-purge() {
  local profile="${1:-default}"
  local disks_dir="$HOME/.colima/_lima/_disks"
  local lima_dir="$HOME/.colima/_lima"

  __show_header "Colima VM" "Purge (WARNING: Destructive Operation)"
  echo "Profile:         ${profile}"
  echo ""
  echo "This operation will:"
  echo "  - Stop all Docker containers"
  echo "  - Remove all Docker images, volumes, and networks"
  echo "  - Stop the Colima VM"
  echo "  - Delete the Colima VM and all its data"
  echo "  - Clean orphan disks and cached assets"
  echo ""
  echo "WARNING: This action cannot be undone!"
  echo ""

  __confirm_operation "Are you sure you want to continue?" || return 1

  docker-purge "${profile}"
  command colima stop --profile "${profile}" --force 2>/dev/null || true
  command colima delete --profile "${profile}" --force 2>/dev/null || true

  # Clean orphan disks
  local -a active=()
  while read -r name _; do
    [[ "$name" != "PROFILE" ]] && active+=("$name")
  done < <(command colima list 2>/dev/null)

  for dir in "$disks_dir"/colima*(/N); do
    local disk="${dir:t}"
    local p
    p=$([[ "$disk" == "colima" ]] && echo "default" || echo "${disk#colima-}")
    if (( ! ${active[(Ie)$p]} )); then
      echo "Removing orphan: $disk"

      rm -rf "${dir:?}" "${lima_dir:?}/${disk:?}"
    fi
  done

  command colima prune --all --force
}

################################################################################
# Docker purge
################################################################################
function docker-purge() {
  local profile="${1:-default}"
  local context
  context="$([[ "${profile}" = "default" ]] && echo "colima" || echo "colima-${profile}")"

  local -a container_ids=()
  while IFS= read -r cid; do
    [ -n "$cid" ] && container_ids+=("$cid")
  done < <(DOCKER_CONTEXT="${context}" command docker ps -aq 2>/dev/null)
  if [ "${#container_ids[@]}" -gt 0 ]; then
    DOCKER_CONTEXT="${context}" command docker stop "${container_ids[@]}" 2>/dev/null || true
  fi

  DOCKER_CONTEXT="${context}" command docker system prune -af --volumes --filter "label!=keep" 2>/dev/null || true
  DOCKER_CONTEXT="${context}" command docker builder prune -af 2>/dev/null || true

  image_ids="$(DOCKER_CONTEXT="${context}" command docker images -q 2>/dev/null)"
  if [ -n "$image_ids" ]; then
    echo "$image_ids" | while IFS= read -r image_id; do
      [ -n "$image_id" ] && DOCKER_CONTEXT="${context}" command docker rmi -f "$image_id" 2>/dev/null || true
    done
  fi
}

################################################################################
# Containerized services
#
# Each service has a custom init (unique Docker config) and standard
# lifecycle functions (start, stop, purge, terminal) that delegate
# to the shared __docker_container_* helpers.
################################################################################

# --- Mongo ---
function mongo-init() {
  mkdir -p "$HOME/Docker/Mongo"
  __docker_run_detached "mongo" \
    --env "MONGO_INITDB_ROOT_USERNAME=mongo" \
    --env "MONGO_INITDB_ROOT_PASSWORD=mongo" \
    --mount "type=bind,source=$HOME/Docker/Mongo,target=/external" \
    --volume "mongo-data:/data/db" \
    --volume "mongo-config:/data/configdb" \
    --publish "127.0.0.1:27017:27017" \
    --health-cmd "mongosh --eval 'db.adminCommand({ping: 1})' --quiet" \
    --health-interval 30s --health-timeout 10s --health-retries 3 \
    mongo:latest
}
mongo-start()    { __docker_container_start "mongo"; }
mongo-stop()     { __docker_container_stop "mongo"; }
mongo-purge()    { __docker_container_purge "mongo"; }
mongo-terminal() { __docker_container_terminal "mongo"; }

# --- Postgres ---
function postgres-init() {
  mkdir -p "$HOME/Docker/Postgres"
  __docker_run_detached "postgres" \
    --env "POSTGRES_USER=postgres" \
    --env "POSTGRES_PASSWORD=postgres" \
    --mount "type=bind,source=$HOME/Docker/Postgres,target=/external" \
    --volume "postgres-data:/var/lib/postgresql/data" \
    --publish "127.0.0.1:5432:5432" \
    --health-cmd "pg_isready -U postgres" \
    --health-interval 30s --health-timeout 10s --health-retries 3 \
    postgres:alpine
}
postgres-start()    { __docker_container_start "postgres"; }
postgres-stop()     { __docker_container_stop "postgres"; }
postgres-purge()    { __docker_container_purge "postgres"; }
postgres-terminal() { __docker_container_terminal "postgres"; }

# --- Redis ---
function redis-init() {
  mkdir -p "$HOME/Docker/Redis"
  __docker_run_detached "redis" \
    --mount "type=bind,source=$HOME/Docker/Redis,target=/external" \
    --volume "redis-data:/data" \
    --publish "127.0.0.1:6379:6379" \
    --health-cmd "redis-cli ping" \
    --health-interval 30s --health-timeout 10s --health-retries 3 \
