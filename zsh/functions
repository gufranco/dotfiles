################################################################################
# Clean and sort a FAT device
################################################################################
function fat_sort() {
  if ! __cmd_exists fatsort; then
    __log_error "fatsort is not installed."
    return 1
  fi

  __fat_sort_find_partition() {
    local device="$1"

    case "$(uname)" in
      Darwin)
        # Already a partition (e.g. /dev/disk4s1)
        if [[ "$device" =~ s[0-9]+$ ]]; then
          echo "$device"
          return 0
        fi

        # Find the FAT partition on the whole disk
        local partition
        partition=$(diskutil list "$device" 2>/dev/null | grep -iE "DOS_FAT|Windows_FAT|Microsoft Basic Data" | awk '{print $NF}' | head -1)

        if [ -n "$partition" ]; then
          echo "/dev/$partition"
          return 0
        fi

        __log_error "No FAT partition found on $device"
        return 1
        ;;
      Linux)
        # Already a partition (e.g. /dev/sdb1)
        if [[ "$device" =~ [0-9]$ ]]; then
          echo "$device"
          return 0
        fi

        echo "${device}1"
        return 0
        ;;
    esac
  }

  __fat_sort_mount_point() {
    local partition="$1"

    case "$(uname)" in
      Darwin)
        diskutil info "$partition" 2>/dev/null | awk -F': +' '/Mount Point/ {print $2}'
        ;;
      Linux)
        command findmnt -n -o TARGET "$partition" 2>/dev/null
        ;;
    esac
  }

  __fat_sort_ensure_mounted() {
    local partition="$1"
    local mount_point

    mount_point=$(__fat_sort_mount_point "$partition")
    if [ -n "$mount_point" ]; then
      echo "$mount_point"
      return 0
    fi

    __log_info "Mounting $partition..."

    case "$(uname)" in
      Darwin)
        if diskutil mount "$partition" >/dev/null 2>&1; then
          mount_point=$(__fat_sort_mount_point "$partition")
          if [ -n "$mount_point" ]; then
            echo "$mount_point"
            return 0
          fi
        fi
        ;;
      Linux)
        mount_point="/tmp/fatsort_$$"
        mkdir -p "$mount_point"
        if sudo mount "$partition" "$mount_point" 2>/dev/null; then
          echo "$mount_point"
          return 0
        fi
        rmdir "$mount_point" 2>/dev/null
        ;;
    esac

    return 1
  }

  __fat_sort_unmount() {
    local partition="$1"

    case "$(uname)" in
      Darwin)
        diskutil unmount "$partition" >/dev/null 2>&1
        ;;
      Linux)
        sudo umount "$partition" 2>/dev/null
        local mount_point="/tmp/fatsort_$$"
        [ -d "$mount_point" ] && rmdir "$mount_point" 2>/dev/null
        ;;
    esac
  }

  __fat_sort_clean() {
    local mount_point="$1"
    local total=0

    __log_info "Cleaning temporary files..."

    local patterns=(
      # macOS
      ".DS_Store"
      ".AppleDB"
      ".AppleDesktop"
      ".AppleDouble"
      ".apdisk"
      ".com.apple.timemachine.donotpresent"
      ".fseventsd"
      ".Spotlight-V100"
      ".TemporaryItems"
      ".Trashes"
      "._*"
      # Windows
      '$RECYCLE.BIN'
      "Desktop.ini"
      "ehthumbs.db"
      "ehthumbs_vista.db"
      "RECYCLER"
      "System Volume Information"
      "Thumbs.db"
      # Linux
      ".directory"
      ".Trash-*"
    )

    for pattern in "${patterns[@]}"; do
      local count
      count=$(command find "$mount_point" -name "$pattern" 2>/dev/null | command wc -l | tr -d ' ')

      if [ "$count" -gt 0 ]; then
        command find "$mount_point" -name "$pattern" -exec rm -rf {} + 2>/dev/null
        total=$((total + count))
        __log_info "  Removed: $pattern ($count)"
      fi
    done

    if [ "$total" -gt 0 ]; then
      __log_success "Cleaned $total items"
    else
      __log_info "No junk files found"
    fi
  }

  local device="$1"

  if [ -z "$device" ]; then
    __log_error "No device specified"
    echo ""
    __log_info "Usage: fat_sort <device>"
    __log_info "       fat_sort /dev/disk4     (macOS, whole disk)"
    __log_info "       fat_sort /dev/disk4s1   (macOS, partition)"
    __log_info "       fat_sort /dev/sdb1      (Linux, partition)"
    return 1
  fi

  if [ ! -b "$device" ] && [ ! -c "$device" ]; then
    __log_error "Device not found: $device"
    return 1
  fi

  local partition
  partition=$(__fat_sort_find_partition "$device") || return 1
  __log_info "Partition: $partition"

  # Mount and clean junk files
  local mount_point
  mount_point=$(__fat_sort_ensure_mounted "$partition")
  if [ -z "$mount_point" ]; then
    __log_error "Failed to mount $partition"
    return 1
  fi

  __log_info "Mounted at: $mount_point"
  __fat_sort_clean "$mount_point"

  # Flush writes and unmount before sorting
  sync
  __log_info "Unmounting..."
  __fat_sort_unmount "$partition"
  sleep 1

  # Sort: alphabetical, case insensitive, directories first
  __log_info "Sorting..."
  if sudo fatsort -c -o d "$partition"; then
    __log_success "Device sorted: $partition"
  else
    __log_error "Failed to sort: $partition"
    return 1
  fi
}

################################################################################
# Download pt-BR subtitles for video files
################################################################################
function subs() {
  if ! __cmd_exists subliminal; then
    __log_error "subliminal is not installed. Install with: pip install subliminal"
    return 1
  fi

  __subs_ensure_utf8() {
    local srt_file="$1"
    local detected
    detected="$(command file --mime-encoding "$srt_file" 2>/dev/null | awk -F': ' '{print $2}')"

    if [ -z "$detected" ]; then
      __log_warning "Could not detect encoding: $(basename "$srt_file")"
      return 1
    fi

    # Already UTF-8: strip BOM if present and move on
    if [ "$detected" = "utf-8" ] || [ "$detected" = "us-ascii" ]; then
      sed -i '' $'1s/^\xEF\xBB\xBF//' "$srt_file" 2>/dev/null
      return 0
    fi

    __log_info "Converting $(basename "$srt_file") from $detected to utf-8"

    local tmp_file="${srt_file}.tmp"
    if iconv -f "$detected" -t utf-8 "$srt_file" > "$tmp_file" 2>/dev/null; then
      sed -i '' $'1s/^\xEF\xBB\xBF//' "$tmp_file" 2>/dev/null
      mv "$tmp_file" "$srt_file"
      __log_success "Converted: $(basename "$srt_file")"
    else
      rm -f "$tmp_file"
      __log_warning "Conversion failed: $(basename "$srt_file"). Trying windows-1252 fallback"

      if iconv -f windows-1252 -t utf-8 "$srt_file" > "$tmp_file" 2>/dev/null; then
        sed -i '' $'1s/^\xEF\xBB\xBF//' "$tmp_file" 2>/dev/null
        mv "$tmp_file" "$srt_file"
        __log_success "Converted (windows-1252 fallback): $(basename "$srt_file")"
      else
        rm -f "$tmp_file"
        __log_error "All conversion attempts failed: $(basename "$srt_file")"
        return 1
      fi
    fi
  }

  __subs_download_for_file() {
    local video_file="$1"
    local basename
    basename="$(basename "$video_file")"

    __log_info "Downloading subtitle: $basename"

    if subliminal download \
      -l pt-BR \
      -HI \
      --force \
      -e utf-8 \
      "$video_file" 2>&1 | grep -v "^$"; then

      # Find the subtitle file that was just downloaded
      local video_name="${video_file%.*}"

      local srt_found=0
      for srt in "${video_name}"*.srt; do
        if [ -f "$srt" ]; then
          __subs_ensure_utf8 "$srt"
          srt_found=1
        fi
      done

      if [ "$srt_found" -eq 0 ]; then
        __log_warning "No subtitle found: $basename"
        return 1
      fi
    else
      __log_warning "subliminal failed: $basename"
      return 1
    fi
  }

  local target="${1:-}"
  local success=0
  local failed=0

  # Single file mode
  if [ -n "$target" ]; then
    if [ ! -f "$target" ]; then
      __log_error "File not found: $target"
      return 1
    fi

    __subs_download_for_file "$target"
    return $?
  fi

  # Directory mode: process all video files in the current directory
  local video_extensions=("mkv" "MKV" "mp4" "MP4" "avi" "AVI" "m4v" "M4V")
  local videos=()

  for ext in "${video_extensions[@]}"; do
    for f in ./*."$ext"; do
      [ -f "$f" ] && videos+=("$f")
    done
  done

  if [ ${#videos[@]} -eq 0 ]; then
    __log_warning "No video files found in the current directory"
    return 1
  fi

  __log_info "Found ${#videos[@]} video files"
  echo ""

  for video in "${videos[@]}"; do
    __subs_download_for_file "$video"
    local result=$?

    if [ "$result" -eq 0 ]; then
      ((success++))
    else
      ((failed++))
    fi

    echo ""
  done

  # Also convert any pre-existing subtitle files
  for srt in ./*.srt; do
    if [ -f "$srt" ]; then
      __subs_ensure_utf8 "$srt"
    fi
  done

  echo ""
  __log_info "==============================================================="
  __log_success "Subtitles: $success downloaded, $failed failed (${#videos[@]} total)"
  __log_info "==============================================================="
  echo ""
}
