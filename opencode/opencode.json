{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-4-e4b": {
          "name": "Gemma 4 E4B",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "lmstudio/google/gemma-4-e4b",
  "small_model": "lmstudio/google/gemma-4-e4b",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".next",
      ".output",
      ".turbo",
      ".vercel",
      ".nuxt",
      ".svelte-kit",
      "coverage",
      "__pycache__",
      ".pytest_cache",
      ".mypy_cache",
      "target",
      "vendor",
      ".terraform",
      ".claude"
    ]
  },
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    },
    "plan": {
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow"
      }
    }
  }
}
