#!/usr/bin/env bash

################################################################################
# Terminal output helpers
################################################################################
function __log_info() {
  local elapsed=0
  local mins=0
  local secs=0

  if [ -n "${SCRIPT_START_TIME:-}" ]; then
    elapsed=$(($(date +%s) - SCRIPT_START_TIME))
    mins=$((elapsed / 60))
    secs=$((elapsed % 60))
    printf "\033[0;34m[INFO]\033[0m [%02d:%02d] %s\n" "$mins" "$secs" "$*"
  else
    printf "\033[0;34m[INFO]\033[0m %s\n" "$*"
  fi
}

