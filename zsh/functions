function __sync_ossc() {
  local folder="OSSC"
  mkdir -p "./$folder/"
  printf "\nProcessing: %s\n" "$folder"

  rclone sync \
    --progress \
    --ignore-case \
    --multi-thread-streams=0 \
    --size-only \
    --delete-excluded \
    --exclude "*.{jic,txt}" \
    --http-url "http://www.infocult.com/m/ossc/fw/v1-series/" \
    ":http:" \
    "./$folder"
}

function sync_games() {
  __sync_redump
  __sync_internet_archive
  __sync_no_intro
  __sync_ossc
}
