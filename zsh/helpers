################################################################################
# Sudo keep-alive helper
################################################################################
# Global variable to store the sudo keeper PID
export __SUDO_KEEPER_PID=""

# Start sudo keep-alive in background
function __start_sudo_keepalive() {
  # Request sudo password once
  sudo -v || return 1

  # Get current shell PID to monitor
  local parent_pid=$$

  # Start sudo keep-alive in background
  # This will refresh sudo every 50 seconds (default timeout is 5 minutes)
  {
    while true; do
      sleep 50
      # Use sudo -v to refresh the timestamp (must not use -n)
      sudo -v 2>/dev/null
      # Exit if parent process is dead
      kill -0 "$parent_pid" 2>/dev/null || exit 0
    done
  } &!
  __SUDO_KEEPER_PID=$!
  export __SUDO_KEEPER_PID

  # Register cleanup on exit
  trap '__stop_sudo_keepalive' EXIT INT TERM

  return 0
}

# Stop sudo keep-alive
function __stop_sudo_keepalive() {
  if [ -n "$__SUDO_KEEPER_PID" ]; then
    kill "$__SUDO_KEEPER_PID" 2>/dev/null || true
    wait "$__SUDO_KEEPER_PID" 2>/dev/null || true
    __SUDO_KEEPER_PID=""
  fi
}

function __cmd_exists() {
  command -v "$1" >/dev/null 2>&1
}

function __pkg_installed() {
  dpkg -l "$1" 2>/dev/null | grep -q "^ii"
}

function __snap_installed() {
  snap list "$1" >/dev/null 2>&1
}

function __safe_link() {
  local src="$1"
  local dst="$2"

  if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$src" ]; then
    __log_skip "Link OK: $dst"
    return 0
  fi

  if [ -e "$dst" ] || [ -L "$dst" ]; then
    rm -rf "$dst"
  fi

  ln -s "$src" "$dst"
  __log_success "Linked: $dst -> $(basename "$src")"
}

function __git_sync() {
  local url="$1"
  local path="$2"
  local depth="${3:-1}"
  local repo_name
  repo_name=$(basename "$path")

  if [ -d "$path/.git" ]; then
    git -C "$path" pull --quiet --no-edit 2>/dev/null || true
    __log_success "Updated: $repo_name"
  else
    rm -rf "$path"
    git clone --quiet --depth="$depth" "$url" "$path" 2>/dev/null || true
    __log_success "Cloned: $repo_name"
  fi
}

################################################################################
# VM / container internal helpers
################################################################################
function __calculate_vm_cores() {
  # Percentage of total CPU cores to allocate
  local percentage=25
  # Minimum number of CPU cores to allocate
  local minimum=2
  # Maximum number of CPU cores to allocate
  local maximum=4
  # Total CPU cores
  local total

  case "$(uname -s)" in
    Darwin)
      total="$(sysctl -n hw.ncpu)"

      ;;
    Linux)
      total="$(nproc)"

      ;;
  esac

  # Calculate percentage
  local result
  result=$(( total * percentage / 100 ))

  # Round up to next even number if odd and >= 2
  if [ "$result" -ge 2 ] && [ $(( result % 2 )) -ne 0 ]; then
    result=$(( result + 1 ))
  fi

  # Cap at maximum
  if [ "$result" -gt "$maximum" ]; then
    result="$maximum"
  fi

  # Apply minimum, but never exceed total available cores
  if [ "$result" -lt "$minimum" ]; then
    if [ "$total" -ge "$minimum" ]; then
      result="$minimum"
    else
      # If total cores < minimum, use total (don't allocate more than available)
      result="$total"
    fi
  fi

  echo "$result"
}

function __calculate_vm_memory() {
  # Percentage of total memory to allocate
  local percentage=50
  # Minimum memory to allocate (in GiB)
  local minimum=2
  # Maximum memory to allocate (in GiB)
  local maximum=16
  # Total memory (in GiB)
  local total

  case "$(uname -s)" in
    Darwin)
      total=$(( "$(sysctl -n hw.memsize)" / 1024 / 1024 / 1024 ))

      ;;
    Linux)
      total=$(( "$(grep MemTotal /proc/meminfo | awk '{print $2}')" / 1024 / 1024 ))

      ;;
  esac

  local result


  result=$(( total * percentage / 100 ))

  # Round up to nearest power of 2 up to maximum
  local rounded=1
  while [ "$rounded" -lt "$result" ] && [ "$rounded" -lt "$maximum" ]; do
    rounded=$(( rounded * 2 ))
  done

  if [ "$rounded" -gt "$maximum" ]; then
    echo "$maximum"

    return
  fi

  if [ "$rounded" -lt "$minimum" ]; then
    echo "$minimum"

    return
  fi

  echo "$rounded"
}

function __calculate_vm_storage() {
  # Percentage of total storage to allocate
  local percentage=25
  # Minimum storage to allocate (in GiB)
  local minimum=8
  # Maximum storage to allocate (in GiB)
  local maximum=64
  # Total storage (in GiB)
  local total

  case "$(uname -s)" in
    Darwin)
      # Get disk size in bytes, convert to GiB, then round up to nearest 256 GiB
      # Formula: ((bytes / 1073741824) + 255) / 256 * 256
      # Example: 500 GB → 512 GB, 750 GB → 768 GB
      # This ensures predictable, power-of-2-aligned sizes
      total=$(( (("$(diskutil info /dev/disk0 | awk -F'[()]' '/Disk Size/ {sub(/ Bytes/, "", $2); print $2}')" / 1073741824) + 255) / 256 * 256 ))

      ;;
    Linux)
      # Get disk size in bytes, convert to GiB, then round up to nearest 256 GiB
      # Same rounding logic as Darwin for consistency
      total=$(( (("$(lsblk -bdno SIZE "/dev/$(lsblk -no pkname "$(df / --output=source | tail -n1)")")" / 1073741824) + 255) / 256 * 256 ))

      ;;
  esac

  local result
  result=$(( total * percentage / 100 ))

  # Round up to nearest power of 2 up to maximum
  local rounded=1
  while [ "$rounded" -lt "$result" ] && [ "$rounded" -lt "$maximum" ]; do
    rounded=$(( rounded * 2 ))
  done

  if [ "$rounded" -gt "$maximum" ]; then
    echo "$maximum"
    return
  fi

  if [ "$rounded" -lt "$minimum" ]; then
    echo "$minimum"
    return
  fi

  echo "$rounded"
}

function __ensure_docker_compose_plugin() {
  if ! command -v docker-compose > /dev/null 2>&1; then
    return
  fi

  local plugin_dir="${HOME}/.docker/cli-plugins"

  if [ ! -d "$plugin_dir" ]; then
    mkdir -p "$plugin_dir"
  fi

  local plugin_path="${plugin_dir}/docker-compose"
  local compose_bin
  compose_bin="$(command -v docker-compose)"

  if [ -L "$plugin_path" ]; then
    local current_target
    current_target="$(readlink "$plugin_path")"

    if [ "$current_target" != "$compose_bin" ]; then
      rm -f "$plugin_path"

      ln -sf "$compose_bin" "$plugin_path"
    fi
  elif [ -e "$plugin_path" ]; then
    rm -f "$plugin_path"

    ln -sf "$compose_bin" "$plugin_path"
  else
    ln -sf "$compose_bin" "$plugin_path"
  fi

  if [ -L "$plugin_path" ] && [ ! -x "$plugin_path" ]; then
    chmod +x "$plugin_path"
  fi
}

function __confirm_colima_config() {
  local profile="$1"
  local cores="$2"
  local memory="$3"
  local storage="$4"
  local os_type="$5"
  local arch="$6"

  echo ""
  echo "================================================================================"
  echo "  Colima VM - Configuration"
  echo "================================================================================"
  echo ""
  echo "Profile:          ${profile}"
  echo "Platform:         ${os_type} (${arch})"
  echo ""
  echo "Configuration:"
  echo "  CPU Cores:      ${cores}"
  echo "  Memory:         ${memory}GiB"
  echo "  Disk:           ${storage}GiB"
  echo ""

  if [[ "${CI:-0}" = "1" ]]; then
    return 0
  fi

  read -r "?Do you want to continue with these configurations? (y/N): "
  echo ""

  if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
    return 1
  fi

  return 0
}

################################################################################
# NPM token management
################################################################################
function __update_npm_token() {
  local force="${1:-false}"
  # shellcheck disable=SC2155
  export NPM_TOKEN_CACHE_FILE="/tmp/npm_token_$(whoami).cache"

  # Force update or check if cache file exists and is not older than 24 hours
  if [ "$force" = "true" ] || [ ! -f "$NPM_TOKEN_CACHE_FILE" ] || [ "$(find "$NPM_TOKEN_CACHE_FILE" -mtime +1 2>/dev/null)" ]; then
    if [ -f "$HOME/.dotfiles/nodejs/tokens/classic.gpg" ]; then
      gpg --quiet --batch --yes -d "$HOME/.dotfiles/nodejs/tokens/classic.gpg" | tr -d '\n' > "$NPM_TOKEN_CACHE_FILE" 2>/dev/null
      chmod 600 "$NPM_TOKEN_CACHE_FILE" 2>/dev/null
    fi
  fi

  # Export token if cache file exists
  if [ -f "$NPM_TOKEN_CACHE_FILE" ]; then
    # shellcheck disable=SC2155
    export NPM_TOKEN="$(cat "$NPM_TOKEN_CACHE_FILE")"
  fi
}
